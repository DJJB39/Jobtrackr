{
  "manifest_version": 3,
  "name": "JobTrackr — Save Jobs Instantly",
  "version": "0.1.0",
  "description": "Save jobs from LinkedIn, Indeed, Reed, and Greenhouse to your JobTrackr board with one click.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.indeed.com/*",
    "*://*.indeed.co.uk/*",
    "*://*.reed.co.uk/*",
    "*://*.greenhouse.io/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/jobs/*",
        "*://*.linkedin.com/job/*",
        "*://*.indeed.com/viewjob*",
        "*://*.indeed.co.uk/viewjob*",
        "*://*.reed.co.uk/jobs/*",
        "*://boards.greenhouse.io/*/jobs/*"
      ],
      "js": ["content.js"],
      "css": [],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
